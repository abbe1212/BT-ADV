# =============================================================================
# BT Agency — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git — it is in .gitignore.
# =============================================================================

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXX"

# Verified sender email in your Resend account
FROM_EMAIL="noreply@yourdomain.com"

# Admin email that receives new booking / lead notifications
ADMIN_EMAIL="admin@yourdomain.com"


# ── Supabase ───────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"

# Publishable / anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="sb_publishable_XXXXXXXX"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_XXXXXXXX"

# Service role key — bypasses RLS, server-side ONLY, never expose to the browser
# Get it from: Dashboard → Settings → API → service_role → Reveal
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXXX"


# ── Cloudinary ────────────────────────────────────────────────────────────────
# Get these from: https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="000000000000000"
CLOUDINARY_API_SECRET="XXXXXXXXXXXXXXXXXXXXXXXX"


# ── Upstash Redis — optional, recommended for 200K+ monthly visits ─────────────
# Without these vars, rate limiting uses an in-memory fallback (sufficient for
# up to ~50K monthly visits on a single Vercel region).
# Get a free Redis database at: https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="XXXXXXXXXXXXXXXXXXXXXXXX"


# ── Sentry Error Tracking (P1.10) ─────────────────────────────────────────────
# Get your DSN from: https://sentry.io → Project → Settings → Client Keys (DSN)
# 1. Create a new Sentry project (Next.js / JavaScript)
# 2. Copy the DSN value shown under SDK Setup
NEXT_PUBLIC_SENTRY_DSN="https://XXXXXXXX@oXXXXXX.ingest.sentry.io/XXXXXXXX"

# For source map uploads in CI (optional but highly recommended):
# Get your auth token from: https://sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN="sntrys_XXXXXXXX"
SENTRY_ORG="your-sentry-org-slug"
SENTRY_PROJECT="bt-agency"


# ── Public Assets ─────────────────────────────────────────────────────────────
# YouTube video ID for the hero cinema background on the Works page.
# The part after youtu.be/ or ?v= in your YouTube URL.
# Example: https://youtu.be/dQw4w9WgXcQ  →  dQw4w9WgXcQ
# Leave empty to hide the video background.
NEXT_PUBLIC_HERO_VIDEO_ID="dQw4w9WgXcQ"
