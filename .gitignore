# =============================================================================
# Next.js / BT Agency — .gitignore
# =============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Build outputs ─────────────────────────────────────────────────────────────
/.next/
/out/
/build
/dist

# ── Testing ───────────────────────────────────────────────────────────────────
/coverage
/.nyc_output

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.test

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel

# ── Supabase local dev ────────────────────────────────────────────────────────
supabase/.branches
supabase/.temp

# ── Debug / logs ──────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Misc ──────────────────────────────────────────────────────────────────────
*.pem
.impeccable.md
.gitignore
.github/copilot-instructions.md
